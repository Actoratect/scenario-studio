{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client", "vite-plugin-pwa/client"]
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../core" },
    { "path": "../ui-kit" },
    { "path": "../adapter-browser" },
    { "path": "../adapter-tauri" },
    { "path": "../adapter-unity" }
  ]
}
