{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Scenario Studio",
  "version": "0.0.0",
  "identifier": "com.actoratect.scenario-studio",
  "build": {
    "beforeDevCommand": "pnpm -F @scenario-studio/frontend dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm -F @scenario-studio/frontend build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scenario Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Multi-target scenario editor (PoC)",
    "longDescription": "Actoratect Scenario Studio — multi-target scenario editor for Browser / Desktop / Unity. PoC-G は dev mode + cargo check 確認まで。production bundle (icon 差替 + signing + auto update) は Phase 3 で。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
