{
  "name": "scenario-studio",
  "private": true,
  "version": "0.0.0",
  "description": "Actoratect Scenario Studio — multi-target scenario editor for Browser / Desktop / Unity.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
